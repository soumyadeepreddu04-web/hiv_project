def tune_classification_models(
    X_train: np.ndarray,
    y_train: np.ndarray,
    groups: np.ndarray,
    logger: RunLogger,
) -> Tuple[Dict[str, Any], pd.DataFrame]:
    cv = StratifiedGroupKFold(n_splits=CLASSIFICATION_CV_FOLDS, shuffle=True, random_state=RANDOM_SEED)
    scoring = {
        "mcc": make_scorer(matthews_corrcoef),
        "pr_auc": "average_precision",
        "roc_auc": "roc_auc",
        "accuracy": "accuracy",
    }
    sample_weight = compute_sample_weight(class_weight="balanced", y=y_train)
    tuned_models: Dict[str, Any] = {}
    cv_results_df = load_tuning_results_checkpoint(CLASSIFICATION_CV_RESULTS_PATH)
    best_params_checkpoint = load_best_params_checkpoint(CLASSIFICATION_BEST_PARAMS_PATH)
    model_specs = classification_model_specs()

    if best_params_checkpoint:
        placeholder_df = checkpoint_placeholder_rows(best_params_checkpoint, "mean_test_mcc", score_is_negative=False)
        if cv_results_df.empty:
            cv_results_df = placeholder_df
        elif "model" in cv_results_df.columns:
            missing_models = set(placeholder_df["model"]) - set(cv_results_df["model"].astype(str))
            if missing_models:
                cv_results_df = pd.concat(
                    [cv_results_df, placeholder_df[placeholder_df["model"].isin(sorted(missing_models))]],
                    ignore_index=True,
                )
        save_tuning_results_checkpoint(CLASSIFICATION_CV_RESULTS_PATH, pd.DataFrame(), "__full__", cv_results_df)

    if best_params_checkpoint:
        logger.log(
            f"Resuming classification tuning with {len(best_params_checkpoint)} cached models: "
            f"{', '.join(sorted(best_params_checkpoint))}"
        )

    for model_name, (estimator, param_distributions) in model_specs.items():
        if model_name in best_params_checkpoint:
            logger.log(f"Restoring checkpointed classification model '{model_name}' on the scaffold-training split.")
            try:
                restored_estimator = clone(estimator).set_params(**best_params_checkpoint[model_name]["params"])
                tuned_models[model_name] = fit_classifier(restored_estimator, X_train, y_train, sample_weight=sample_weight)
                logger.log(f"Skipping classification model '{model_name}' because it is already checkpointed.")
                continue
            except Exception as error:
                logger.log(
                    f"  Failed to restore checkpointed classification model '{model_name}': "
                    f"{error.__class__.__name__}: {error}. Retuning from scratch."
                )

        logger.log(f"Tuning classification model '{model_name}' with {CLASSIFICATION_CV_FOLDS}-fold CV")
        try:
            search = RandomizedSearchCV(
                estimator=estimator,
                param_distributions=param_distributions,
                n_iter=CLASSIFICATION_SEARCH_ITERATIONS,
                scoring=scoring,
                refit="mcc",
                cv=cv,
                random_state=RANDOM_SEED,
                n_jobs=1,
                return_train_score=False,
                error_score="raise",
            )
            try:
                search.fit(X_train, y_train, groups=groups, sample_weight=sample_weight)
            except TypeError:
                search.fit(X_train, y_train, groups=groups)

            tuned_models[model_name] = search.best_estimator_
            best_params = to_jsonable(search.best_params_)
            logger.log(f"  Best {model_name}: CV MCC={search.best_score_:.3f}, params={best_params}")
            results_df = pd.DataFrame(search.cv_results_)
            trimmed = results_df[
                ["rank_test_mcc", "mean_test_mcc", "std_test_mcc", "mean_test_pr_auc", "mean_test_roc_auc", "mean_test_accuracy", "params"]
            ].copy().sort_values("rank_test_mcc").head(10)
            trimmed["model"] = model_name
            trimmed["params"] = trimmed["params"].apply(lambda value: json.dumps(to_jsonable(value), sort_keys=True))
            cv_results_df = save_tuning_results_checkpoint(CLASSIFICATION_CV_RESULTS_PATH, cv_results_df, model_name, trimmed)
            best_params_checkpoint[model_name] = {
                "params": best_params,
                "primary_score": float(search.best_score_),
            }
            save_best_params_checkpoint(CLASSIFICATION_BEST_PARAMS_PATH, best_params_checkpoint)
        except Exception as error:
            logger.log(f"  Classification tuning failed for '{model_name}': {error}")
            logger.log(f"  Skipping classification model '{model_name}' and continuing with the remaining tuned models.")
            continue

    if not tuned_models:
        raise RuntimeError("No classification models were successfully tuned or restored from checkpoint.")

    if cv_results_df.empty and best_params_checkpoint:
        cv_results_df = checkpoint_placeholder_rows(best_params_checkpoint, "mean_test_mcc", score_is_negative=False)

    return tuned_models, cv_results_df


