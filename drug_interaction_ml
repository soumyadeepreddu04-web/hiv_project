        save_feature_benchmark_checkpoint("regression", rows)

    benchmark_df = pd.DataFrame(rows).sort_values(["mean_rmse", "mean_mae", "mean_r2"], ascending=[True, True, False]).reset_index(drop=True)
    best_representation = str(benchmark_df.iloc[0]["representation"])
    logger.log(f"Best regression representation: {best_representation} (mean RMSE={benchmark_df.iloc[0]['mean_rmse']:.3f})")
