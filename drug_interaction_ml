class GroupAwareStackingClassifier:
    def __init__(self, base_models: Dict[str, Any], meta_model: Any) -> None:
        self.base_models = base_models
        self.meta_model = meta_model

    def predict_proba(self, X: np.ndarray) -> np.ndarray:
        stacked_features = np.column_stack([predict_positive_probability(model, X) for model in self.base_models.values()])
        return np.asarray(self.meta_model.predict_proba(stacked_features))

    def predict(self, X: np.ndarray) -> np.ndarray:
        return (self.predict_proba(X)[:, 1] >= 0.5).astype(int)


def train_group_aware_stacking_classifier(
    base_estimators: Dict[str, Any],
    X_train: np.ndarray,
    y_train: np.ndarray,
    groups: np.ndarray,
    logger: RunLogger,
) -> GroupAwareStackingClassifier:
    cv = StratifiedGroupKFold(n_splits=CLASSIFICATION_CV_FOLDS, shuffle=True, random_state=RANDOM_SEED)
    estimator_names = list(base_estimators.keys())
    oof_predictions = np.zeros((len(y_train), len(estimator_names)), dtype=np.float32)

    for fold_number, (fit_idx, valid_idx) in enumerate(cv.split(X_train, y_train, groups), start=1):
        logger.log(f"Training stacking fold {fold_number}/{CLASSIFICATION_CV_FOLDS}")
        fold_weights = compute_sample_weight(class_weight="balanced", y=y_train[fit_idx])
        for column_index, estimator_name in enumerate(estimator_names):
            estimator = clone(base_estimators[estimator_name])
            fit_classifier(estimator, X_train[fit_idx], y_train[fit_idx], sample_weight=fold_weights)
            oof_predictions[valid_idx, column_index] = predict_positive_probability(estimator, X_train[valid_idx])

    meta_model = LogisticRegression(max_iter=2000, solver="liblinear", random_state=RANDOM_SEED, class_weight="balanced")
    meta_weights = compute_sample_weight(class_weight="balanced", y=y_train)
    fit_classifier(meta_model, oof_predictions, y_train, sample_weight=meta_weights)

    fitted_base_models: Dict[str, Any] = {}
    full_weights = compute_sample_weight(class_weight="balanced", y=y_train)
    for estimator_name, estimator in base_estimators.items():
        fitted_estimator = clone(estimator)
        fit_classifier(fitted_estimator, X_train, y_train, sample_weight=full_weights)
        fitted_base_models[estimator_name] = fitted_estimator

    return GroupAwareStackingClassifier(base_models=fitted_base_models, meta_model=meta_model)


def simple_smote(X_train: np.ndarray, y_train: np.ndarray, random_state: int = RANDOM_SEED) -> Tuple[np.ndarray, np.ndarray]:
    labels, counts = np.unique(y_train, return_counts=True)
    if len(labels) != 2:
        return X_train, y_train

    minority_label = labels[np.argmin(counts)]
    majority_count = int(np.max(counts))
    minority_mask = y_train == minority_label
    X_minority = X_train[minority_mask]
    samples_needed = majority_count - len(X_minority)

    if samples_needed <= 0:
        return X_train, y_train
    if len(X_minority) < 2:
        repeated = np.repeat(X_minority, samples_needed, axis=0)
        synthetic_y = np.full(samples_needed, minority_label, dtype=y_train.dtype)
        return np.vstack([X_train, repeated]), np.concatenate([y_train, synthetic_y])

    n_neighbors = min(SMOTE_K_NEIGHBORS, len(X_minority) - 1)
    rng = np.random.default_rng(random_state)
    neighbor_model = NearestNeighbors(n_neighbors=n_neighbors + 1)
    neighbor_model.fit(X_minority)
    neighbor_indices = neighbor_model.kneighbors(return_distance=False)

    synthetic = np.zeros((samples_needed, X_train.shape[1]), dtype=np.float32)
    for row_index in range(samples_needed):
        anchor_index = int(rng.integers(0, len(X_minority)))
        choices = neighbor_indices[anchor_index][1:]
        neighbor_index = int(rng.choice(choices)) if len(choices) else anchor_index
        gap = float(rng.random())
        synthetic[row_index] = X_minority[anchor_index] + gap * (X_minority[neighbor_index] - X_minority[anchor_index])

    synthetic_y = np.full(samples_needed, minority_label, dtype=y_train.dtype)
    return np.vstack([X_train, synthetic]), np.concatenate([y_train, synthetic_y])


def evaluate_classification_models(
    models: Dict[str, Any],
    X_test: np.ndarray,
    y_test: np.ndarray,
    split_name: str,
    logger: RunLogger | None = None,
) -> List[ClassificationResult]:
    results: List[ClassificationResult] = []
    for model_name, model in models.items():
        if logger is not None:
            logger.log(f"  Evaluating classification model '{model_name}'")
        try:
            y_prob = predict_positive_probability(model, X_test)
            metrics = classification_metrics_from_probabilities(y_test, y_prob)
            y_pred = (y_prob >= 0.5).astype(int)
            results.append(
                ClassificationResult(
                    name=model_name,
                    split=split_name,
                    accuracy=float(metrics["accuracy"]),
                    roc_auc=float(metrics["roc_auc"]),
                    pr_auc=float(metrics["pr_auc"]),
                    precision=float(metrics["precision"]),
                    recall=float(metrics["recall"]),
                    f1=float(metrics["f1"]),
                    mcc=float(metrics["mcc"]),
                    y_prob=y_prob,
                    y_pred=y_pred,
                )
            )
            if logger is not None:
                logger.log(
                    f"    {model_name}: MCC={metrics['mcc']:.3f}, PR-AUC={metrics['pr_auc']:.3f}, "
                    f"ROC-AUC={metrics['roc_auc']:.3f}"
                )
        except Exception as error:
            if logger is not None:
                logger.log(f"    Evaluation failed for '{model_name}': {error.__class__.__name__}: {error}")
            continue

    if not results:
        raise RuntimeError(f"All classification evaluations failed for split '{split_name}'.")

    return results


