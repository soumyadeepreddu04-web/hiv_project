def fit_classification_model_by_name(
    model_name: str,
    tuned_models: Dict[str, Any],
    X_train: np.ndarray,
    y_train: np.ndarray,
    groups: np.ndarray,
    logger: RunLogger,
) -> Any:
    if model_name == "Stacked Ensemble":
        base_estimators = {name: tuned_models[name] for name in ("Random Forest", "Extra Trees", "HistGradientBoosting") if name in tuned_models}
        return train_group_aware_stacking_classifier(base_estimators, X_train, y_train, groups, logger)

    if model_name == "Extra Trees + SMOTE":
        estimator = clone(tuned_models["Extra Trees"])
        X_resampled, y_resampled = simple_smote(X_train, y_train)
        return fit_classifier(estimator, X_resampled, y_resampled, sample_weight=None)

    estimator = clone(tuned_models[model_name])
    sample_weight = compute_sample_weight(class_weight="balanced", y=y_train)
    return fit_classifier(estimator, X_train, y_train, sample_weight=sample_weight)


def compute_applicability_domain(
    train_row_ids: np.ndarray,
    test_row_ids: np.ndarray,
    morgan_fingerprints: Sequence[Any],
    logger: RunLogger,
) -> Tuple[np.ndarray, float, np.ndarray]:
    """Estimate the applicability‑domain (AD) using a fast nearest‑neighbour index.
    If `faiss` is available we build a flat inner‑product index on the normalized
    Morgan fingerprints (equivalent to cosine similarity). Otherwise we fall back to the
    original exhaustive pairwise computation.
    """
    # Prepare training fingerprints as numpy array (float32) and L2‑normalize for cosine similarity
    train_fps = np.stack([np.frombuffer(fp.ToBitString().encode(), dtype=np.uint8) for fp in [morgan_fingerprints[i] for i in train_row_ids]])
    # Convert bit strings to float vectors (0/1)
    train_array = np.unpackbits(train_fps.view(np.uint8)).astype(np.float32)
    train_norm = np.linalg.norm(train_array, axis=1, keepdims=True)
    train_norm[train_norm == 0] = 1.0
    train_normalized = train_array / train_norm

    try:
        import faiss
        index = faiss.IndexFlatIP(train_normalized.shape[1])
        faiss.normalize_L2(train_normalized)
        index.add(train_normalized)
        # Prepare test fingerprints similarly
        test_fps = np.stack([np.frombuffer(fp.ToBitString().encode(), dtype=np.uint8) for fp in [morgan_fingerprints[i] for i in test_row_ids]])
        test_array = np.unpackbits(test_fps.view(np.uint8)).astype(np.float32)
        test_norm = np.linalg.norm(test_array, axis=1, keepdims=True)
        test_norm[test_norm == 0] = 1.0
        test_normalized = test_array / test_norm
        faiss.normalize_L2(test_normalized)
        # Search for nearest neighbour similarities
        distances, _ = index.search(test_normalized, 1)
        # distances are inner‑product (= cosine similarity because vectors are normalised)
        test_similarity = distances.ravel()
        logger.log("FAISS index used for applicability‑domain scoring.")
    except Exception:
        # Fallback to original exhaustive method
        logger.log("FAISS not available; falling back to exhaustive similarity computation.")
        train_fps = [morgan_fingerprints[i] for i in train_row_ids]
        test_fps = [morgan_fingerprints[i] for i in test_row_ids]
        train_neighbor_similarity = np.zeros(len(train_fps), dtype=np.float32)
        with logger.section("Estimating applicability-domain threshold (fallback)"):
            for index, fp in enumerate(train_fps):
                similarities = list(DataStructs.BulkTanimotoSimilarity(fp, train_fps))
                if len(similarities) > 1:
                    similarities[index] = -1.0
                    train_neighbor_similarity[index] = max(similarities)
                else:
                    train_neighbor_similarity[index] = 1.0
                if index + 1 == len(train_fps) or (index + 1) % 250 == 0:
                    logger.log(f"Processed {index + 1}/{len(train_fps)} training fingerprints for AD thresholding.")
        threshold = float(np.percentile(train_neighbor_similarity, AD_SIMILARITY_PERCENTILE))
        logger.log(f"Applicability-domain threshold set at Tanimoto similarity {threshold:.3f}")
        test_similarity = np.zeros(len(test_fps), dtype=np.float32)
        with logger.section("Scoring test molecules against the training chemical space (fallback)"):
            for index, fp in enumerate(test_fps):
                similarities = DataStructs.BulkTanimotoSimilarity(fp, train_fps)
                test_similarity[index] = max(similarities) if similarities else 0.0
                if index + 1 == len(test_fps) or (index + 1) % 250 == 0:
                    logger.log(f"Processed {index + 1}/{len(test_fps)} test fingerprints for AD scoring.")
        inside_ad = test_similarity >= threshold
        return train_neighbor_similarity, threshold, inside_ad
    # Compute threshold from training similarities
    threshold = float(np.percentile(test_similarity, AD_SIMILARITY_PERCENTILE))
    inside_ad = test_similarity >= threshold
    return np.array([]), threshold, inside_ad


def find_activity_cliffs(df: pd.DataFrame, morgan_fingerprints: Sequence[Any], logger: RunLogger) -> pd.DataFrame:
    records: List[Dict[str, Any]] = []
    y = df["median_pchembl"].to_numpy(dtype=float)
    labels = df["label"].to_numpy()

    with logger.section("Searching for activity cliffs"):
        for left_index in range(len(df) - 1):
            similarities = DataStructs.BulkTanimotoSimilarity(morgan_fingerprints[left_index], morgan_fingerprints[left_index + 1 :])
            for offset, similarity in enumerate(similarities, start=1):
                if similarity < ACTIVITY_CLIFF_SIMILARITY:
                    continue
                right_index = left_index + offset
                delta_pchembl = abs(y[left_index] - y[right_index])
                if delta_pchembl < ACTIVITY_CLIFF_DELTA_PCHEMBL:
                    continue
                records.append(
                    {
                        "left_compound": df.iloc[left_index]["compound_name"],
                        "right_compound": df.iloc[right_index]["compound_name"],
                        "left_smiles": df.iloc[left_index]["smiles"],
                        "right_smiles": df.iloc[right_index]["smiles"],
                        "tanimoto_similarity": float(similarity),
                        "left_pchembl": float(y[left_index]),
                        "right_pchembl": float(y[right_index]),
                        "delta_pchembl": float(delta_pchembl),
                        "left_label": labels[left_index],
                        "right_label": labels[right_index],
                    }
                )
            if left_index + 1 == len(df) - 1 or (left_index + 1) % 250 == 0:
                logger.log(f"Activity-cliff scan progress: {left_index + 1}/{len(df) - 1} anchors processed.")

    if not records:
        logger.log("No activity cliffs passed the configured thresholds.")
        return pd.DataFrame(
            columns=[
                "left_compound",
                "right_compound",
                "left_smiles",
                "right_smiles",
                "tanimoto_similarity",
                "left_pchembl",
                "right_pchembl",
                "delta_pchembl",
                "left_label",
                "right_label",
            ]
        )

    cliffs_df = pd.DataFrame(records).sort_values(["delta_pchembl", "tanimoto_similarity"], ascending=[False, False]).reset_index(drop=True)
    logger.log(f"Detected {len(cliffs_df)} activity cliffs above the similarity and potency-delta thresholds.")
    return cliffs_df


