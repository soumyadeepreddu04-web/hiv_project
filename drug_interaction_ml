            tuned_regression_models,
            regression_X_test,
            y_reg_test,
            split_name="scaffold",
            logger=logger,
        )

    regression_results: List[RegressionResult] = list(scaffold_regression_results)
    logger.log(f"Computed scaffold regression metrics for {len(scaffold_regression_results)} model(s).")
    best_scaffold_regressor = min(scaffold_regression_results, key=lambda result: result.rmse)
    logger.log(
        f"Best scaffold-holdout regressor: {best_scaffold_regressor.name} "
        f"(RMSE={best_scaffold_regressor.rmse:.3f}, R2={best_scaffold_regressor.r2:.3f})"
    )

    if regression_temporal_split is not None:
        temporal_train_df, temporal_test_df, _ = regression_temporal_split
        temporal_train_ids = temporal_train_df["dataset_index"].to_numpy(dtype=int)
        temporal_test_ids = temporal_test_df["dataset_index"].to_numpy(dtype=int)
        temporal_X_train, _ = compose_feature_matrix(feature_blocks, best_regression_representation, row_ids=temporal_train_ids)
        temporal_X_test, _ = compose_feature_matrix(feature_blocks, best_regression_representation, row_ids=temporal_test_ids)
        temporal_y_train = temporal_train_df["median_pchembl"].to_numpy(dtype=float)
        temporal_y_test = temporal_test_df["median_pchembl"].to_numpy(dtype=float)
        with logger.section("Evaluating best regressor on temporal split"):
            temporal_model = clone(tuned_regression_models[best_scaffold_regressor.name])
            fit_regressor(temporal_model, temporal_X_train, temporal_y_train)
            regression_results.extend(
                evaluate_regression_models(
                    {best_scaffold_regressor.name: temporal_model},
                    temporal_X_test,
                    temporal_y_test,
                    split_name="temporal",
                    logger=logger,
                )
            )

    classification_metrics_df = classification_results_to_frame(classification_results)
    regression_metrics_df = regression_results_to_frame(regression_results)
    classification_metrics_df.to_csv(CLASSIFICATION_METRICS_PATH, index=False)
    regression_metrics_df.to_csv(REGRESSION_METRICS_PATH, index=False)

    plot_roc_curves(scaffold_classification_results, y_class_test, ROC_PLOT_PATH)
    plot_precision_recall_curves(scaffold_classification_results, y_class_test, PR_PLOT_PATH)
    importance_model, importance_model_name = select_feature_importance_model(scaffold_classification_models, scaffold_classification_results)
    plot_feature_importance(importance_model, classification_feature_names, IMPORTANCE_PLOT_PATH)
    logger.log(f"Feature-importance plot written using {importance_model_name}.")

    best_regression_model = tuned_regression_models[best_scaffold_regressor.name]
    plot_regression_predictions(y_reg_test, best_regression_model.predict(regression_X_test), REGRESSION_PLOT_PATH)

    _, ad_threshold, inside_ad = compute_applicability_domain(
        classification_train_row_ids,
        classification_test_row_ids,
        feature_blocks.morgan_fingerprints,
        logger,
    )

    best_scaffold_classification_result = next(result for result in scaffold_classification_results if result.name == best_scaffold_classifier.name)
    classification_predictions_df = classification_test_df.copy()
    classification_predictions_df["predicted_probability"] = best_scaffold_classification_result.y_prob
    classification_predictions_df["predicted_label"] = best_scaffold_classification_result.y_pred
    classification_predictions_df["inside_applicability_domain"] = inside_ad
    classification_predictions_df.to_csv(CLASSIFICATION_PREDICTIONS_PATH, index=False)

    regression_predictions_df = regression_test_df.copy()
    regression_predictions_df["predicted_pchembl"] = best_scaffold_regressor.y_pred
    regression_predictions_df.to_csv(REGRESSION_PREDICTIONS_PATH, index=False)

    activity_cliffs_df = find_activity_cliffs(curated_df, feature_blocks.morgan_fingerprints, logger)
    activity_cliffs_df.to_csv(ACTIVITY_CLIFF_PATH, index=False)

    report = {
        "runtime": {
            "backend": runtime.backend,
            "adapters": runtime.adapters,
            "gpu_name": runtime.gpu_name,
            "message": runtime.message,
        },
        "dataset": {
            "curated_molecules": int(len(curated_df)),
            "classification_molecules": int(len(classification_df)),
            "regression_molecules": int(len(regression_df)),
            "classification_train": int(len(classification_train_df)),
            "classification_test": int(len(classification_test_df)),
            "regression_train": int(len(regression_train_df)),
            "regression_test": int(len(regression_test_df)),
        },
        "features": {
            "classification_representation": best_classification_representation,
            "regression_representation": best_regression_representation,
        },
        "classification": classification_metrics_df.to_dict(orient="records"),
        "regression": regression_metrics_df.to_dict(orient="records"),
        "applicability_domain": {"threshold": ad_threshold, "inside_fraction": float(np.mean(inside_ad))},
        "activity_cliffs": {
            "count": int(len(activity_cliffs_df)),
            "top_examples": activity_cliffs_df.head(5).to_dict(orient="records"),
        },
    }
    RUN_REPORT_PATH.write_text(json.dumps(report, indent=2), encoding="utf-8")

    print_summary(
        runtime=runtime,
        curated_df=curated_df,
        classification_df=classification_df,
        regression_df=regression_df,
        classification_train_df=classification_train_df,
        classification_test_df=classification_test_df,
        regression_train_df=regression_train_df,
        regression_test_df=regression_test_df,
        best_classification_representation=best_classification_representation,
        best_regression_representation=best_regression_representation,
        classification_results=classification_results,
        regression_results=regression_results,
        ad_threshold=ad_threshold,
        inside_ad_fraction=float(np.mean(inside_ad)),
        activity_cliffs_count=int(len(activity_cliffs_df)),
    )


if __name__ == "__main__":
    try:
        main()
    except Exception:
        traceback_text = traceback.format_exc()
        print(traceback_text, flush=True)
        try:
            with RUN_LOG_PATH.open("a", encoding="utf-8") as handle:
                handle.write(traceback_text)
                if not traceback_text.endswith("\n"):
                    handle.write("\n")
        except OSError:
            pass
        raise
