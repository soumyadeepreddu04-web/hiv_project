    logger.log(
        f"Run profile = {RUN_PROFILE}; CPU workers = {MAX_PARALLEL_WORKERS}; "
        f"classification CV = {CLASSIFICATION_CV_FOLDS}; regression CV = {REGRESSION_CV_FOLDS}; "
        f"classification search iters = {CLASSIFICATION_SEARCH_ITERATIONS}; regression search iters = {REGRESSION_SEARCH_ITERATIONS}; "
        f"benchmark trees = {FEATURE_BENCHMARK_TREES}"
