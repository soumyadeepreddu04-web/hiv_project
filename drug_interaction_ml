from __future__ import annotations

import json
import traceback

import pandas as pd

from dti_pipeline.config import (
    CLASSIFICATION_BEST_PARAMS_PATH,
    CLASSIFICATION_CONFIG_PATH,
    CLASSIFICATION_CV_RESULTS_PATH,
    CLASSIFICATION_EXTERNAL_PATH,
    CLASSIFICATION_INTERNAL_TRAIN_PATH,
    CLASSIFICATION_LEAKAGE_REPORT_PATH,
    CLASSIFICATION_METRICS_PATH,
    CLASSIFICATION_NESTED_PREDICTIONS_PATH,
    CLASSIFICATION_PREDICTIONS_PATH,
    CLASSIFICATION_REPRESENTATION,
    CLASSIFICATION_TUNING_RESULTS_PATH,
    FEATURE_BENCHMARK_PATH,
    OUTER_CV_FOLDS,
    INNER_CV_FOLDS,
    CLASSIFICATION_SEARCH_ITERATIONS,
    RANDOM_SEED,
    ROC_PLOT_PATH,
    PR_PLOT_PATH,
    IMPORTANCE_PLOT_PATH,
    ACTIVITY_CLIFF_PATH,
    RUN_LOG_PATH,
    RUN_PROFILE,
    RUN_REPORT_PATH,
    ClassificationResult,
    RunLogger,
    write_json,
)
from dti_pipeline.data import (
    build_classification_dataset,
    build_classification_splits,
    build_regression_dataset,
    build_temporal_split,
    load_or_build_dataset,
    scaffold_groups,
    split_classification_dataset,
)
from dti_pipeline.evaluation import (
    build_error_analysis,
    build_leakage_report,
    build_prediction_frame,
    classification_results_to_frame,
    compute_applicability_domain,
    detect_runtime,
    find_activity_cliffs,
    plot_feature_importance,
    plot_feature_importance_interactive,
    plot_precision_recall_curves,
    plot_precision_recall_curves_interactive,
    plot_roc_curves,
    plot_roc_curves_interactive,
    print_summary,
    select_feature_importance_model,
)
from dti_pipeline.features import compose_feature_matrix, featurize_dataset
from dti_pipeline.training import (
    evaluate_final_models_on_external,
    fit_final_models,
    run_nested_cv,
    select_champion_model,
    summarize_nested_cv_results,
)


def main() -> None:
    logger = RunLogger(RUN_LOG_PATH)
    runtime = detect_runtime()
    logger.log(runtime.message)
    logger.log(
        f"Run profile={RUN_PROFILE}; representation={CLASSIFICATION_REPRESENTATION}; "
        f"outer_folds={OUTER_CV_FOLDS}; inner_folds={INNER_CV_FOLDS}; "
        f"search_iterations={CLASSIFICATION_SEARCH_ITERATIONS}; seed={RANDOM_SEED}"
    )

    curated_df = load_or_build_dataset(logger)
    classification_df = build_classification_dataset(curated_df, logger)
    _ = build_regression_dataset(curated_df, logger)
    feature_blocks = featurize_dataset(curated_df, logger)

    split_bundle = build_classification_splits(classification_df, logger)
    internal_train_df = split_bundle["internal_train"]
    external_df = split_bundle["external_validation"]
    external_strategy = str(split_bundle["external_strategy"])
    feature_manifest_df = pd.DataFrame(
        [
            {
                "task": "classification",
                "representation": CLASSIFICATION_REPRESENTATION,
                "selection_mode": "fixed_predefined",
                "used_for_primary_evaluation": True,
            }
        ]
    )
    feature_manifest_df.to_csv(FEATURE_BENCHMARK_PATH, index=False)
    logger.log(
        f"Using fixed representation '{CLASSIFICATION_REPRESENTATION}' for the primary scaffold-group evaluation. "
        "No data-driven feature recipe selection is performed before nested CV."
    )

    internal_row_ids = internal_train_df["dataset_index"].to_numpy(dtype=int)
    external_row_ids = external_df["dataset_index"].to_numpy(dtype=int)
    X_internal, classification_feature_names = compose_feature_matrix(feature_blocks, CLASSIFICATION_REPRESENTATION, row_ids=internal_row_ids)
    X_external, _ = compose_feature_matrix(feature_blocks, CLASSIFICATION_REPRESENTATION, row_ids=external_row_ids)
    y_internal = internal_train_df["label"].to_numpy(dtype=int)
    y_external = external_df["label"].to_numpy(dtype=int)
    groups_internal = scaffold_groups(internal_train_df)

    with logger.section("Running nested cross-validation"):
        nested_fold_df, nested_prediction_df, nested_tuning_df = run_nested_cv(
            X=X_internal,
            y=y_internal,
            groups=groups_internal,
            row_ids=internal_row_ids,
            logger=logger,
        )
    nested_summary_df = summarize_nested_cv_results(nested_fold_df)
    champion_model = select_champion_model(nested_summary_df)
    logger.log(f"Champion model selected from nested CV: {champion_model}")

    nested_fold_export = nested_fold_df.copy()
    nested_fold_export["params"] = nested_fold_export["params"].apply(lambda value: json.dumps(value, sort_keys=True) if isinstance(value, dict) else value)
    nested_fold_export.to_csv(CLASSIFICATION_CV_RESULTS_PATH, index=False)
    nested_prediction_df.to_csv(CLASSIFICATION_NESTED_PREDICTIONS_PATH, index=False)

    tuning_export_df = pd.concat([nested_tuning_df], ignore_index=True)
    tuning_export_df["params"] = tuning_export_df["params"].apply(lambda value: json.dumps(value, sort_keys=True) if isinstance(value, dict) else value)

    with logger.section("Fitting final calibrated models on the internal training set"):
        final_artifacts, final_tuning_df = fit_final_models(
            X=X_internal,
            y=y_internal,
            groups=groups_internal,
            logger=logger,
    )

    final_tuning_export = final_tuning_df.copy()
    final_tuning_export["params"] = final_tuning_export["params"].apply(lambda value: json.dumps(value, sort_keys=True) if isinstance(value, dict) else value)
    tuning_export_df = pd.concat([tuning_export_df, final_tuning_export], ignore_index=True)
    tuning_export_df.to_csv(CLASSIFICATION_TUNING_RESULTS_PATH, index=False)

    best_params_payload = {
        model_name: {
            "params": artifact.params,
            "threshold": artifact.threshold,
            "calibration_method": artifact.calibration_method,
            "internal_oof_metrics": artifact.oof_metrics,
        }
        for model_name, artifact in final_artifacts.items()
    }
    write_json(CLASSIFICATION_BEST_PARAMS_PATH, best_params_payload)

    with logger.section("Evaluating final models on the external validation set"):
        external_results = evaluate_final_models_on_external(
            artifacts=final_artifacts,
            X_external=X_external,
            y_external=y_external,
            split_name=external_strategy,
            logger=logger,
        )

    _, ad_threshold, inside_ad = compute_applicability_domain(
        internal_row_ids,
        external_row_ids,
        feature_blocks.morgan_fingerprints,
        logger,
    )

    prediction_df = build_prediction_frame(
        external_df=external_df,
        external_results=external_results,
        champion_model=champion_model,
        inside_ad=inside_ad,
    )
    prediction_df.to_csv(CLASSIFICATION_PREDICTIONS_PATH, index=False)

    error_analysis_df, error_summary_df = build_error_analysis(prediction_df, champion_model)

    leakage_report = build_leakage_report(
        train_df=internal_train_df,
        test_df=external_df,
        feature_blocks=feature_blocks,
        logger=logger,
    )
    write_json(CLASSIFICATION_CONFIG_PATH, {
        "random_seed": RANDOM_SEED,
        "run_profile": RUN_PROFILE,
        "outer_cv_folds": OUTER_CV_FOLDS,
        "inner_cv_folds": INNER_CV_FOLDS,
        "search_iterations": CLASSIFICATION_SEARCH_ITERATIONS,
        "representation": CLASSIFICATION_REPRESENTATION,
        "representation_selection_mode": "fixed_predefined",
        "feature_scaling": "pipeline_train_only",
        "smote_policy": "applied_only_within_training_folds_for_smote_models",
        "external_strategy": external_strategy,
        "internal_train_path": str(CLASSIFICATION_INTERNAL_TRAIN_PATH),
        "external_validation_path": str(CLASSIFICATION_EXTERNAL_PATH),
    })

    write_json(CLASSIFICATION_EXTERNAL_PATH.with_suffix(".metadata.json"), split_bundle["external_metadata"])
    write_json(CLASSIFICATION_LEAKAGE_REPORT_PATH, leakage_report)

    classification_metrics_df = classification_results_to_frame(nested_summary_df, external_results, champion_model)
    classification_metrics_df.to_csv(CLASSIFICATION_METRICS_PATH, index=False)

    plot_roc_curves(external_results, y_external, ROC_PLOT_PATH)
    plot_precision_recall_curves(external_results, y_external, PR_PLOT_PATH)
    importance_model, importance_model_name = select_feature_importance_model(final_artifacts, external_results)
    plot_feature_importance(importance_model, classification_feature_names, IMPORTANCE_PLOT_PATH)
    logger.log(f"Feature-importance plot written using {importance_model_name}.")

    activity_cliffs_df = find_activity_cliffs(curated_df, feature_blocks.morgan_fingerprints, logger)
    activity_cliffs_df.to_csv(ACTIVITY_CLIFF_PATH, index=False)

    report = {
        "runtime": {
            "backend": runtime.backend,
            "adapters": runtime.adapters,
            "gpu_name": runtime.gpu_name,
            "message": runtime.message,
        },
        "dataset": {
            "curated_molecules": int(len(curated_df)),
            "classification_molecules": int(len(classification_df)),
            "internal_train_rows": int(len(internal_train_df)),
            "external_validation_rows": int(len(external_df)),
            "external_strategy": external_strategy,
            "external_metadata": split_bundle["external_metadata"],
        },
        "features": {
            "representation_used": CLASSIFICATION_REPRESENTATION,
            "selection_mode": "fixed_predefined",
            "feature_scaling": "pipeline_train_only",
            "benchmark_results": feature_manifest_df.to_dict(orient="records"),
        },
        "nested_cv_summary": nested_summary_df.to_dict(orient="records"),
        "external_validation": classification_metrics_df[classification_metrics_df["stage"] == "external_validation"].to_dict(orient="records"),
        "champion_model": champion_model,
        "leakage_report": leakage_report,
        "applicability_domain": {
            "threshold": ad_threshold,
            "inside_fraction": float(inside_ad.mean()),
        },
        "error_summary": error_summary_df.to_dict(orient="records"),
        "activity_cliffs": {
            "count": int(len(activity_cliffs_df)),
            "top_examples": activity_cliffs_df.head(5).to_dict(orient="records"),
        },
    }
    write_json(RUN_REPORT_PATH, report)

    print_summary(
        runtime=runtime,
        curated_df=curated_df,
        classification_df=classification_df,
        internal_train_df=internal_train_df,
        external_df=external_df,
        representation=CLASSIFICATION_REPRESENTATION,
        nested_summary_df=nested_summary_df,
        external_results=external_results,
        champion_model=champion_model,
        external_strategy=external_strategy,
        leakage_report=leakage_report,
        ad_threshold=ad_threshold,
        inside_ad_fraction=float(inside_ad.mean()),
        activity_cliffs_count=int(len(activity_cliffs_df)),
    )


if __name__ == "__main__":
    try:
        main()
    except Exception:
        traceback_text = traceback.format_exc()
        print(traceback_text, flush=True)
        try:
            with RUN_LOG_PATH.open("a", encoding="utf-8") as handle:
                handle.write(traceback_text)
                if not traceback_text.endswith("\n"):
                    handle.write("\n")
        except OSError:
            pass
